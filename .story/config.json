{
  "features": {
    "handovers": true,
    "issues": true,
    "reviews": true,
    "roadmap": true,
    "tickets": true
  },
  "language": "typescript",
  "project": "Stratarius",
  "schemaVersion": 2,
  "type": "npm",
  "version": 2,
  "recipeOverrides": {
    "stages": {
      "VERIFY": {
        "enabled": true,
        "readinessUrl": "http://localhost:3000",
        "startCommand": "npm run dev"
      }
    },
    "codexReviewBackends": [
      "lenses",
      "codex"
    ],
    "maxTicketsPerSession": 0,
    "reviewBackends": [
      "lenses",
      "codex",
      "agent"
    ],
    "handoverInterval": 3
  }
}
