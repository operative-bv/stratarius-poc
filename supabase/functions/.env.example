# ============================================================================
# Stratarius — Supabase Edge Functions env template (Deno runtime)
# ============================================================================
# These variables are read by Deno.env.get(...) inside supabase/functions/*.
# In production they are set via `supabase secrets set KEY=value` (not via a
# .env file on the Supabase host). Locally, `supabase start` and `supabase
# functions serve` will read a .env file next to this template if present.
#
# Note (project decision N-005 pending): the Stripe billing surface may be
# ripped out of the POC. If so, these variables and the corresponding
# billing-functions/ + billing-webhooks/ folders can be removed entirely.
# ============================================================================


# ---- Stripe -----------------------------------------------------------------
# Local dev + Supabase test project: use test-mode keys (sk_test_..., whsec_...).
# Production: use live-mode keys from Stripe dashboard. NEVER commit live keys.
# Basejump's canonical names — do NOT rename (would break billing-functions).

STRIPE_API_KEY=sk_test_asdf
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_asdf
STRIPE_DEFAULT_PLAN_ID=price_asdf

# Trial days granted to new subscriptions.
STRIPE_DEFAULT_TRIAL_DAYS=30


# ---- App URLs ---------------------------------------------------------------
# Allowed hosts for Stripe billing-portal return URLs.
# Local dev: http://localhost:3000
# Production: the deployed app URL (must match NEXT_PUBLIC_URL in root .env).
# If you need multiple allowed hosts, edit billing-functions/index.ts directly.

ALLOWED_HOST=http://localhost:3000
