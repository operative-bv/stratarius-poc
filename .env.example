# ============================================================================
# Stratarius — environment template
# ============================================================================
# Copy this file to `.env.local` for local dev, or set these as environment
# variables in your production host (Vercel dashboard, etc.). `.env` is
# gitignored — never commit real values.
#
# Deployment target (assumption per project decision N-009): Vercel EU +
# Supabase managed EU (Frankfurt). Adjust regions/URLs when confirmed.
# ============================================================================


# ---- Supabase ---------------------------------------------------------------
# Local dev: `supabase start` prints these values on the CLI. Use them here to
# talk to the local stack (URL = http://127.0.0.1:54321, ANON_KEY = long JWT).
# Production: copy from your Supabase project dashboard → Settings → API.
#              Prefer a project in an EU region for GDPR data-residency.

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — NEVER expose to the browser (do NOT prefix with NEXT_PUBLIC_).
# Grants full DB access, bypassing RLS. Per constitution's Domain section:
# "Cross-tenant queries zijn niet mogelijk zonder service-role bypass, die
#  enkel in audit- en migratiescripts wordt gebruikt en per gebruik gelogd."
# Concrete users of this key: parameter-snapshot audit (T-021), GDPR-audit RPC
# for mart_loonkloof reads (T-034), migration/backfill scripts that need to
# bypass RLS. Do NOT use in normal server actions — those inherit user RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ---- App URLs ---------------------------------------------------------------
# NEXT_PUBLIC_URL is used to generate invitation links and Stripe return URLs.
# Local dev: http://localhost:3000
# Production: full https URL of the deployed app (e.g. https://app.stratarius.be)

NEXT_PUBLIC_URL=http://localhost:3000
